@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
    ViewData["PageTitle"] = "Headlight";
}

<link rel="stylesheet" href="~/css/index.css">

<div class="index-container">
    <div class="container">
        <div id="echarts-doughnut" style="width: 100%; height: 100%;"></div>
    </div>
    <div class="flex-column">
        <div class="container">
            <select id="timeFrameSelect" onchange="onSelectChange();">
                <option value="0">Monthly</option>
                <option value="1">Yearly</option>
                <option value="2">All Time</option>
            </select>
        </div>
        <div class="container">
            <h2 id="finished-banner">0</h2>
            <p id="finished-description">Finished Games</p>
        </div>
    </div>
    <div class="randomgame-container">
        <h2 id="randomgame-banner">
            <a id="randomgame-name-link" href="#"></a>
        </h2>
        <p id="randomgame-description"></p>
    </div>
</div>

<script src="~/js/libs/echarts.min.js"></script>
<script src="~/js/index.js"></script>
