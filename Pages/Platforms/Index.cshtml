@page
@using Headlight.Models
@model Headlight.Pages.Platforms.IndexModel
@{
    ViewData["Title"] = ViewData["PageTitle"] = "Platforms";
}

<link rel="stylesheet" href="~/css/Games/index.css">

<div class="games-page-topbar">
    <div class="games-searchbar-container container">
        <input type="search" name="searchInput" id="searchInput" placeholder="Find platform..." />
    </div>
    <div class="games-add-game-container container">
        <form method="post">
            <button type="submit" asp-page-handler="AddPlatform">Add Platform</button>
        </form>
    </div>
</div>
<hr />
<div class="games-game-list">
    <table class="games-game-list">
        @if (Model.AllPlatforms.Count > 0)
        {
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Game Count</th>
                </tr>
            </thead>
            <tbody>
                    @foreach (Platform platform in Model.AllPlatforms)
                    {
                    string hrefTarget = Url.Page("/Platforms/View", new { PlatformId = platform.Id }) ?? "";
                    string deleteTarget = Url.Page("/Platforms/Delete", new { PlatformId = platform.Id }) ?? "";
                    <tr>
                        <td>
                            <div onclick="location.href = '@hrefTarget'" style="cursor: pointer;">
                                @platform.Name
                            </div>
                        </td>
                        <td>@platform.Games?.Count</td>
                        <td>
                            @if (platform.Id > 1)
                            {
                                <div class="games-delete-icon container" onclick="location.href='@deleteTarget'" style="cursor: pointer;">
                                    <svg viewBox="0 0 512 512" version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <title>trashcan</title> <g id="Page-1" stroke="none" stroke-width="1" fill="none" fill-rule="evenodd"> <g id="Shape" fill="#dc2e2e" transform="translate(64.000000, 42.666667)"> <path d="M256,42.6666667 L128,42.6666667 L128,7.10542736e-15 L256,7.10542736e-15 L256,42.6666667 Z M170.666667,170.666667 L128,170.666667 L128,341.333333 L170.666667,341.333333 L170.666667,170.666667 Z M256,170.666667 L213.333333,170.666667 L213.333333,341.333333 L256,341.333333 L256,170.666667 Z M384,85.3333333 L384,128 L341.333333,128 L341.333333,426.666667 L42.6666667,426.666667 L42.6666667,128 L0,128 L0,85.3333333 L384,85.3333333 Z M298.666667,128 L85.3333333,128 L85.3333333,384 L298.666667,384 L298.666667,128 Z"> </path> </g> </g> </g></svg>
                                </div>
                            }
                        </td>
                    </tr>
                    }
            </tbody>
        }
        else
        {
            <tbody>
                <tr><td>No rows to show.</td></tr>
            </tbody>
        }
    </table>
</div>


