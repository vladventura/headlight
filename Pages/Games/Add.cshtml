@page
@model Headlight.Pages.Games.AddModel
@{
    ViewData["Title"] = "Games";
    ViewData["PageTitle"] = "Add Game";
}

<link rel="stylesheet" href="~/css/Games/add.css">

<form method="post">
    @if (!string.IsNullOrEmpty(Model.PageMessage))
    {
        <small class="@Model.PageMessageCssClass">@Model.PageMessage</small>
    }

    <div class="container">
        <label for="Name">Name</label>
        <input type="text" name="Name" id="Name" />
    </div>
    <div class="container">
        <label for="AddedDateTime">Added Date</label>
        <input type="date" name="AddedDateTime" id="AddedDateTime" value="@DateTime.Now.ToLocalTime().ToString("yyyy-MM-dd")"/>
    </div>
    <div class="container">
        <label for="StatusId">Status</label>
        <select name="StatusId" aria-label="Status Id" required>
            @foreach (var status in Model.Statuses)
            {
                <option value="@status.Id">@status.Name</option>
            }
        </select>
    </div>
    <div class="container">
        <label for="PlatformId">Platform</label>
        <select name="PlatformId" aria-label="Platform Id" required>
                @foreach (var platform in Model.Platforms)
                {
                    <option value="@platform.Id">@platform.Name</option>
                }
            </select>
    </div>
    <button asp-page-handler="SaveChanges">Add</button>
    <button asp-page-handler="CancelChanges">Cancel</button>
</form>
