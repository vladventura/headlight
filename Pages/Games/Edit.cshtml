@page "/Games/{gameId:int}/Edit"
@model Headlight.Pages.Games.EditModel
@{
    ViewData["Title"] = "Edit";
}

@if (Model.SelectedGame != null)
{
    DateTime addedValue = new(Model.SelectedGame.AddedDateTime?.Ticks ?? DateTime.Now.Ticks, DateTimeKind.Unspecified);

    <form method="post">
        @if (Model.MessageResult != null)
        {
            <small class="@Model.PageMessageCssClass">@Model.Message</small>
        }

        <div class="container">
            <label for="Name">Name</label>
            <input type="text" name="Name" id="Name" value="@Model.SelectedGame.Name"/>
        </div>
        <div class="container">
            <label for="AddedDateTime">Added Date</label>
            <input type="date" name="AddedDateTime" id="AddedDateTime" value="@addedValue.ToLocalTime().ToString("yyyy-MM-dd")" />
        </div>
        <div class="container">
            <label for="StatusId">Status</label>
            <select name="StatusId" aria-label="Status Id" required>
                @foreach (var status in Model.Statuses)
                {
                        string? selected = Model.SelectedGame.StatusId == status.Id ? "selected" : null;
                        <option value="@status.Id" selected="@selected">@status.Name</option>
                }
            </select>
        </div>
        <div class="container">
            <label for="PlatformId">Platform</label>
            <select name="PlatformId" aria-label="Platform Id" required>
                @foreach (var platform in Model.Platforms)
                {
                    string? selected = Model.SelectedGame.PlatformId == platform.Id ? "selected" : null;
                    <option value="@platform.Id" selected="@selected">@platform.Name</option>
                }
            </select>
        </div>
        <button asp-page-handler="SaveChanges">Save</button>
        <button asp-page-handler="CancelChanges">Cancel</button>
    </form>
}
else
{
    <div class="container">
        <span>No game found with id @Model.GameId</span>
    </div>

    <div>
        <a asp-page="/Games/Index">Go back</a>
    </div>
}