@page
@model Headlight.Pages.Games.IndexModel
@{
    ViewData["Title"] = "Games";
}

<div class="table-page-topbar">
    <div class="container">
        <input type="search" name="searchInput" id="searchInput" placeholder="Find game..." />
    </div>
    <div class="table-page-add-container container">
        <form method="post">
            <button type="submit" asp-page-handler="AddGame">Add Game</button>
        </form>
    </div>
</div>

@if (Model.MessageResult != null)
{
    <small class="@Model.PageMessageCssClass">@Model.Message</small>
}

<hr />

<div class="table-page-list">
    <partial name="_SearchableTablePartial" model="@Model.SearchableTableData" />
</div>
