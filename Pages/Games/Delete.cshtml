@page "/Games/{gameId:int}/Delete"
@model Headlight.Pages.Games.DeleteModel
@{
    ViewData["Title"] = "Delete";
}

@if (Model.SelectedGame != null)
{
    <hgroup>
        <h1>Deleting @Model.SelectedGame?.Name</h1>
        <p>Are you sure you want to delete this game?</p>
    </hgroup>
    <hr />
    <form method="post">
        <div class="container">
            <button asp-page-handler="ConfirmDelete">Delete</button>
            <button asp-page-handler="CancelChanges">Cancel</button>
        </div>
    </form>
}
else
{
    <hgroup>
        <h1>Not found</h1>
        <p>Game with ID @Model.GameId not found.</p>
    </hgroup>

}
