@inject IConfiguration _config

@{
    bool hideNavBar = (bool)(ViewData["HideNavBar"] ?? false);
    string returnText = hideNavBar ? "Go Back" : "Index";
    Layout = "_BaseLayout";
}

<div class="main-container">
    <div class="page-title container">
        <header class="header">
            <h2>@ViewData["PageTitle"]</h2>
        </header>
    </div>
    <div class="app container">
        <div class="navbar container">
            <aside>
                <nav>
                    <ul>
                        <li>
                            <a asp-page="/Index">@returnText</a>
                        </li>
                        @if (!hideNavBar)
                        {
                            <li>
                                <details style="margin: 0;">
                                    <summary>Games</summary>
                                    <p><a asp-page="/Games/Index">All </a></p>
                                    <p><a asp-page="/Games/Index" asp-route-statusidfilter="1">Backlog</a></p>
                                    <p><a asp-page="/Games/Index" asp-route-statusidfilter="2">Playing</a></p>
                                    <p><a asp-page="/Games/Index" asp-route-statusidfilter="3">Finished</a></p>
                                </details>
                            </li>
                            <li><a asp-page="/Platforms/Index">Platforms</a></li>
                            <li><a asp-page="/Statuses/Index">Statuses</a></li>
                            <li><a asp-page="/Settings/ImportData">Import Data</a></li>
                        }
                    </ul>
                </nav>
            </aside>
            @if (hideNavBar)
            {
                @await RenderSectionAsync("navbar", required: false)
            }
        </div>
        <div class="page container">
            <main role="main" class="render-body-container">
                <script src="~/lib/jquery/dist/jquery.min.js"></script>
                @RenderBody()
            </main>
        </div>
    </div>
    <div class="main-footer">
        <span><a href="https://github.com/vladventura">@@vladventura</a></span>
        <span>v@_config["AppVersion"]</span>
    </div>
</div>