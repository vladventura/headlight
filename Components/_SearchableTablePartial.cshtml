@using Headlight.Models.Components;
@using Headlight.AppCode;
@model SearchableTableData;

@{
    string tableClassString = Model.HtmlAttributes ?? "";
    string htmlId = SearchableTableData.HtmlId;
    string htmlClass = SearchableTableData.HtmlClass;
    int dataRowCount = Model.Rows.Count;
}

<link rel="stylesheet" href="~/css/Components/searchable-table.css">

<table id="@htmlId" class="@htmlClass" data-rowcount="@dataRowCount">
    <thead>
        <tr>
            @foreach(SearchableTableColumn column in Model.Columns.OrderBy(c => c.Index))
            {
                string columnHtmlAttrs = column.HtmlAttributes ?? "";
                <th @Html.Raw(columnHtmlAttrs)>
                    @column.Key
                </th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach(SearchableTableRow row in Model.Rows)
        {
            string rowHtmlAttrs = row.HtmlAttributes ?? "";
            <tr @Html.Raw(rowHtmlAttrs)>
                @foreach(SearchableTableRowCell cell in row.Cells)
                {
                    string cellHtmlAttrs = cell.HtmlAttributes ?? "";
                    <td @Html.Raw(cellHtmlAttrs)>
                        @if (cell.ShouldRender)
                        {
                            @if (cell.Clickable)
                            {
                                string clickableHtmlAttributes = string.Format("style=\"cursor: pointer;\" {0}", cell.ClickableHtmlAttributes ?? "");
                                <div @Html.Raw(clickableHtmlAttributes)>
                                    @if (cell.Icon != null)
                                    {
                                        string partialName = Utils.GetIconPartial(cell.Icon.Value);
                                        string partialClass = Utils.GetIconCssClass(cell.Icon.Value);
                                        <div class="@partialClass">
                                            @await Html.PartialAsync(partialName)
                                        </div>
                                    }
                                    else
                                    {
                                        @cell.Value
                                    }
                                </div> 
                            }
                            else
                            {
                                @cell.Value
                            }
                        }
                    </td>
                }
            </tr>
        }
    </tbody>
</table>

<script src="~/js/libs/fdb-all.min.js" type="text/javascript"></script>
<script src="~/js/libs/typeahead.js"></script>
<script src="~/js/Components/searchable-table.js"></script>
